{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/preinstall-check.cjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "deploy:test-link": "node ./scripts/deploy-test-link.mjs",
    "hash:admin-password": "node ./scripts/hash-admin-password.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "smoke:deploy-local": "node ./scripts/smoke-deploy-local.mjs",
    "smoke:deploy": "node ./scripts/smoke-deploy.mjs"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
