# Copy this file to .env.production before a real launch.
# Do not commit your filled-in .env.production file.

PORT=3000

POSTGRES_USER=fd_admin
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=fd_allocator

DATABASE_URL=postgresql://fd_admin:replace-with-a-long-random-postgres-password@postgres:5432/fd_allocator

SESSION_SECRET=replace-with-a-long-random-session-secret
ADMIN_USERS_JSON=[{"email":"admin@example.com","name":"Front Desk Admin","passwordHash":"replace-with-output-from-pnpm-run-hash:admin-password"}]

PUBLIC_APP_URL=https://your-subdomain.duckdns.org
TRUST_PROXY=true
